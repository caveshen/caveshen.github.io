---
// HoodedFigure.astro — hooded placeholder figure, authored once, rendered into all three scenes.
// Props place it in each SVG's coordinate space; overflow/cropping is handled by the scene's viewBox.
// Fills are literal hex — theme-independent by design. Classes, not IDs (three copies coexist).
// Ported verbatim from the converged mock (docs/PRD §14, 2026-07-21):
//   - #face-shadow group DELETED (Rembrandt face explicitly rejected)
//   - mote particles NOT ported (belong to mock's stand-in backdrop, not the figure)
//   - hotspot rect NOT ported (replaced by the real <button> approach prompt)

interface Props {
  x: number;
  y: number;
  scale?: number;
}
const { x, y, scale = 1 } = Astro.props;
---

<g class="hooded-figure" transform={`translate(${x},${y}) scale(${scale})`}>

  <!-- ground shadow -->
  <ellipse cx="0" cy="196" rx="50" ry="11" fill="rgba(0,0,0,0.35)"/>

  <!-- legs / jeans (more leg shows below the shorter hem) -->
  <path d="M -24 96 L -27 188 L -9 188 L -7 100 Z" fill="#2b2f3f" stroke="#14151c" stroke-width="2.5" stroke-linejoin="round"/>
  <path d="M 24 96 L 27 188 L 9 188 L 7 100 Z" fill="#2b2f3f" stroke="#14151c" stroke-width="2.5" stroke-linejoin="round"/>
  <!-- shoes -->
  <path d="M -30 186 L -7 186 L -7 196 L -32 196 Q -34 190 -30 186 Z" fill="#1a1c26" stroke="#14151c" stroke-width="2"/>
  <path d="M 30 186 L 7 186 L 7 196 L 32 196 Q 34 190 30 186 Z" fill="#1a1c26" stroke="#14151c" stroke-width="2"/>

  <!-- hoodie body (hip-length, boxy) -->
  <path d="M -46 42 Q -51 38 -49 54 L -45 92 Q -45 102 -35 102 L 35 102 Q 45 102 45 92 L 49 54 Q 51 38 46 42 Q 22 30 0 30 Q -22 30 -46 42 Z"
        fill="#464d63" stroke="#14151c" stroke-width="3" stroke-linejoin="round"/>
  <!-- right-side shading panel -->
  <path d="M 0 32 Q 23 32 46 42 L 49 54 L 45 92 Q 45 100 39 101 L 0 101 Z" fill="#3a3f52" opacity="0.85"/>
  <!-- ARMS: sleeve panels on each flank, forearms angling into the pocket.
       Drawn before the pocket so the pocket overlaps the cuffs = hands tucked in. -->
  <path d="M -44 38 Q -51 42 -50 58 Q -49 71 -43 77 Q -35 81 -29 70 L -31 60 Q -35 49 -37 39 Z"
        fill="#414759" stroke="#14151c" stroke-width="2" stroke-linejoin="round"/>
  <path d="M 44 38 Q 51 42 50 58 Q 49 71 43 77 Q 35 81 29 70 L 31 60 Q 35 49 37 39 Z"
        fill="#414759" stroke="#14151c" stroke-width="2" stroke-linejoin="round"/>
  <!-- armhole seams — the line that makes an arm read as an arm -->
  <path d="M -37 39 Q -34 52 -31 62" fill="none" stroke="#2b3040" stroke-width="1.6" stroke-linecap="round"/>
  <path d="M 37 39 Q 34 52 31 62"   fill="none" stroke="#2b3040" stroke-width="1.6" stroke-linecap="round"/>
  <!-- ribbed cuffs at the wrists (sleeve cuffs, above the elbow) -->
  <g stroke="#2b3040" stroke-width="1.5" stroke-linecap="round">
    <line x1="-45" y1="66" x2="-33" y2="70"/><line x1="-44" y1="71" x2="-32" y2="75"/>
    <line x1="45" y1="66" x2="33" y2="70"/><line x1="44" y1="71" x2="32" y2="75"/>
  </g>
  <!-- ribbed hem -->
  <g stroke="#2f3446" stroke-width="1.5" stroke-linecap="round">
    <line x1="-30" y1="94" x2="-30" y2="101"/>
    <line x1="-15" y1="94" x2="-15" y2="101"/>
    <line x1="0"   y1="94" x2="0"   y2="101"/>
    <line x1="15"  y1="94" x2="15"  y2="101"/>
    <line x1="30"  y1="94" x2="30"  y2="101"/>
  </g>
  <!-- kangaroo pocket, hands tucked in -->
  <path d="M -30 62 Q 0 74 30 62 L 26 82 Q 0 90 -26 82 Z" fill="#3a3f52" stroke="#22222e" stroke-width="1.5"/>
  <path d="M -30 62 L -20 66" stroke="#20222c" stroke-width="2.5" stroke-linecap="round"/>
  <path d="M 30 62 L 20 66"  stroke="#20222c" stroke-width="2.5" stroke-linecap="round"/>
  <!-- ribbed cuffs at the wrists -->
  <g stroke="#2f3446" stroke-width="1.4" stroke-linecap="round">
    <line x1="-30" y1="78" x2="-24" y2="82"/>
    <line x1="30"  y1="78" x2="24"  y2="82"/>
  </g>

  <!-- ===== hood: a cowl with the head recessed inside ===== -->
  <!-- back drape (behind the head, gives the hood volume) -->
  <path d="M -45 48 Q -58 -10 -30 -26 Q 0 -38 30 -26 Q 58 -10 45 48 Q 38 42 30 42 L -30 42 Q -38 42 -45 48 Z"
        fill="#3f4560" stroke="#14151c" stroke-width="2.5" stroke-linejoin="round"/>
  <!-- recessed interior void (the face is an empty shadow — no feature art inside) -->
  <path class="face-void" d="M -25 22 Q -22 0 0 -2 Q 22 0 25 22 L 22 42 Q 0 50 -22 42 Z" fill="#0c0e15"/>
  <!-- hood front, framing the face opening; overhangs the brow -->
  <path d="M -42 48 Q -50 -6 -27 -21 Q 0 -31 27 -21 Q 50 -6 42 48
           Q 34 44 27 30 Q 23 8 0 6 Q -23 8 -27 30 Q -34 44 -42 48 Z"
        fill="#4a5169" stroke="#14151c" stroke-width="3" stroke-linejoin="round"/>
  <!-- tunnel-depth shadow just inside the opening -->
  <path d="M -24 12 Q 0 6 24 12" fill="none" stroke="#05060a" stroke-width="2.4" stroke-linecap="round" opacity="0.6"/>
  <!-- fabric folds -->
  <path d="M -7 -20 Q -19 2 -25 28" fill="none" stroke="#3a4058" stroke-width="1.6" stroke-linecap="round" opacity="0.85"/>
  <path d="M 7 -20 Q 19 2 25 28"   fill="none" stroke="#3a4058" stroke-width="1.6" stroke-linecap="round" opacity="0.85"/>
  <path d="M 0 -27 Q 2 -12 0 4"    fill="none" stroke="#3a4058" stroke-width="1.4" stroke-linecap="round" opacity="0.6"/>
  <!-- warm rim light (city glow) — constant, not themed -->
  <path d="M -42 48 Q -50 -6 -27 -21" fill="none" stroke="#ffd27a" stroke-width="2.4" stroke-linecap="round" opacity="0.55"/>
  <path d="M -46 42 Q -51 38 -49 54 L -45 90" fill="none" stroke="#ffd27a" stroke-width="2.2" stroke-linecap="round" opacity="0.4"/>

  <!-- drawstrings — flutter in the wind (.sway) -->
  <g class="sway">
    <line x1="-8" y1="46" x2="-9" y2="72" stroke="#e6e2d6" stroke-width="2.4" stroke-linecap="round"/>
    <line x1="8"  y1="46" x2="9"  y2="72" stroke="#e6e2d6" stroke-width="2.4" stroke-linecap="round"/>
    <circle cx="-9" cy="73" r="2" fill="#e6e2d6"/>
    <circle cx="9"  cy="73" r="2" fill="#e6e2d6"/>
  </g>

</g>

<style is:global>
  /* Drawstring wind flutter — belongs to the figure, not the scene backdrop */
  .sway {
    transform-box: fill-box;
    transform-origin: center top;
    animation: sway 3.4s ease-in-out infinite alternate;
  }
  @keyframes sway {
    from { transform: rotate(-5deg); }
    to   { transform: rotate(5deg);  }
  }

  @media (prefers-reduced-motion: reduce) {
    .sway { animation: none; }
  }
</style>
