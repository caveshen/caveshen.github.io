---
import '../styles/tokens.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  bodyClass?: string;
}

const {
  title = "Caveshen Rajman",
  description = "PLACEHOLDER — Caveshen Rajman's portfolio.",
  ogImage = "/og-image.png",
  bodyClass = "",
} = Astro.props;

const canonicalURL = Astro.url.toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <!-- Inline: set data-time before first paint to avoid flash -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem("time");
        if (t === "day") document.documentElement.dataset.time = "day";
        // Night is the default — no attribute needed
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background-color: var(--bg);
    color: var(--text);
    font-family: var(--serif);
    transition: var(--theme-transition);
    min-height: 100vh;
    /* PRD §17.1: without this, .stage-frame's own top margin collapses
       through body (its first in-flow child, since the toggle button is
       position:absolute), pushing body's whole box 1rem below the viewport
       and, combined with min-height:100vh, causing a page-height overflow
       that has nothing to do with actual content. flow-root establishes a
       new block-formatting context so the margin stays inside body instead.
       No visible effect at any breakpoint — verified by measurement. */
    display: flow-root;
  }
</style>
