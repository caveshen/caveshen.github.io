---
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import HoodedFigure from '../components/HoodedFigure.astro';
import CityScape from '../components/CityScape.astro';
import tree from '../data/dialogue.json';
const root = tree.root;

// One world, three cameras (PRD §14) — pan + uniform scale only, never a stretch.
// This is what fixed the "three different hand-drawn mountains" bug: the world
// (CityScape.astro) is authored once and each aspect only pans/scales the camera.
const CAMERA = {
  std:  'translate(0,128)',
  wide: 'translate(280,128)',
  tall: 'translate(-20,262) scale(0.62)',
};

// Foreground placement per aspect — free to differ per view (unlike the world).
// Standard/Wide share a camera height, so they share the figure's scale too;
// Tall steps back. HoodedFigure's y prop is a translate origin, not the feet
// position, so we convert: the figure's own shoe-line sits at local y=196.
const FIG = {
  std:  { x: 700,  y: 700 - 196 * 1.2, scale: 1.2 },
  wide: { x: 1290, y: 700 - 196 * 1.2, scale: 1.2 },
  tall: { x: 300,  y: 940 - 196 * 1.3, scale: 1.3 },
};
---
<Base
  title="The Interview — Caveshen Rajman"
  description="PLACEHOLDER — Caveshen Rajman's interactive portfolio. An adventure-game-styled CV for games industry and tech contacts."
>
  <!-- Toggle: first in DOM so it's first in tab order -->
  <ThemeToggle />

  <!--
    stage-frame: a full-height stage — a place to stand in, not a letterbox strip.
    overflow:hidden clips the camera zoom; .camera carries the transform.
    The dialogue card lives inside it as an in-scene overlay (PRD §14 restage).
  -->
  <div class="stage-frame">
  <div class="camera">

  <!-- ============ STANDARD 1200×750 ============ -->
  <svg class="scene scene-standard" viewBox="0 0 1200 750" preserveAspectRatio="xMidYMax slice" role="img"
       aria-label="Cape Town's Table Mountain, Lion's Head and Signal Hill above the city bowl, by night or day, with a hooded figure on the promenade">
    <rect class="f-sky" width="1200" height="750" />
    <g class="f-star night-only">
      <circle cx="95"   cy="70"  r="1.6" opacity="0.8" />
      <circle cx="240"  cy="120" r="1.2" opacity="0.5" />
      <circle cx="410"  cy="55"  r="1.4" opacity="0.7" />
      <circle cx="560"  cy="105" r="1.1" opacity="0.45" />
      <circle cx="700"  cy="45"  r="1.5" opacity="0.75" />
      <circle cx="1050" cy="60"  r="1.3" opacity="0.6" />
      <circle cx="1150" cy="140" r="1.1" opacity="0.4" />
      <circle cx="320"  cy="160" r="1.0" opacity="0.35" />
      <circle cx="820"  cy="190" r="1.2" opacity="0.5" />
      <circle cx="150"  cy="230" r="1.0" opacity="0.35" />
    </g>
    <!-- moon (night) — pale and cratered, radius locked at 46 -->
    <g class="night-only">
      <circle class="f-moon" cx="930" cy="150" r="46" />
      <g class="f-crater" opacity="0.55">
        <circle cx="914" cy="136" r="8" /><circle cx="947" cy="164" r="5.5" />
        <circle cx="939" cy="128" r="3.5" /><circle cx="908" cy="166" r="4.5" />
      </g>
    </g>
    <!-- sun + clouds (day) -->
    <g class="day-only">
      <circle class="f-cel" cx="930" cy="150" r="50" />
      <rect x="120" y="140" width="150" height="22" rx="11" fill="#fff" opacity="0.85" />
      <rect x="620" y="105" width="110" height="20" rx="10" fill="#fff" opacity="0.7" />
    </g>
    <CityScape camera={CAMERA.std} />
    <!-- sea -->
    <rect class="f-sea" y="480" width="1200" height="120" />
    <g class="f-moon night-only">
      <rect x="900" y="502" width="60" height="3" rx="1.5" opacity="0.35" />
      <rect x="915" y="530" width="34" height="3" rx="1.5" opacity="0.2" />
      <rect x="908" y="556" width="44" height="3" rx="1.5" opacity="0.14" />
    </g>
    <!-- the near shore — promenade the figure stands on -->
    <rect class="f-ground" y="600" width="1200" height="150" />
    <!-- semi-foreground railing: in front of the water, behind the figure -->
    <g class="f-rail" stroke-linecap="round" stroke-width="7">
      <g stroke-width="5">
        <line x1="40" y1="590" x2="40" y2="654" /><line x1="200" y1="590" x2="200" y2="654" />
        <line x1="360" y1="590" x2="360" y2="654" /><line x1="520" y1="590" x2="520" y2="654" />
        <line x1="680" y1="590" x2="680" y2="654" /><line x1="840" y1="590" x2="840" y2="654" />
        <line x1="1000" y1="590" x2="1000" y2="654" /><line x1="1160" y1="590" x2="1160" y2="654" />
      </g>
      <line x1="0" y1="592" x2="1200" y2="592" />
      <line x1="0" y1="624" x2="1200" y2="624" stroke-width="4" opacity="0.8" />
    </g>
    <HoodedFigure x={FIG.std.x} y={FIG.std.y} scale={FIG.std.scale} />
  </svg>

  <!-- ============ WIDE 1750×750 (21:9) ============ -->
  <svg class="scene scene-wide" viewBox="0 0 1750 750" preserveAspectRatio="xMidYMax slice" role="img"
       aria-label="Cape Town skyline panorama, by night or day, with a hooded figure on the promenade">
    <rect class="f-sky" width="1750" height="750" />
    <g class="f-star night-only">
      <circle cx="95" cy="70" r="1.6" opacity="0.8" /><circle cx="340" cy="120" r="1.2" opacity="0.5" />
      <circle cx="610" cy="55" r="1.4" opacity="0.7" /><circle cx="860" cy="105" r="1.1" opacity="0.45" />
      <circle cx="1100" cy="45" r="1.5" opacity="0.75" /><circle cx="1450" cy="90" r="1.3" opacity="0.6" />
      <circle cx="1650" cy="140" r="1.1" opacity="0.4" /><circle cx="520" cy="160" r="1.0" opacity="0.35" />
      <circle cx="1180" cy="200" r="1.4" opacity="0.7" /><circle cx="240" cy="230" r="1.1" opacity="0.45" />
      <circle cx="1560" cy="55" r="1.3" opacity="0.6" /><circle cx="760" cy="190" r="1.0" opacity="0.35" />
    </g>
    <g class="night-only">
      <circle class="f-moon" cx="1290" cy="150" r="46" />
      <g class="f-crater" opacity="0.55">
        <circle cx="1274" cy="136" r="8" /><circle cx="1307" cy="164" r="5.5" />
        <circle cx="1299" cy="128" r="3.5" /><circle cx="1268" cy="166" r="4.5" />
      </g>
    </g>
    <g class="day-only">
      <circle class="f-cel" cx="1290" cy="150" r="50" />
      <rect x="250" y="140" width="150" height="22" rx="11" fill="#fff" opacity="0.85" />
      <rect x="900" y="105" width="110" height="20" rx="10" fill="#fff" opacity="0.7" />
      <rect x="1480" y="185" width="130" height="20" rx="10" fill="#fff" opacity="0.75" />
    </g>
    <CityScape camera={CAMERA.wide} />
    <!-- foreground: same camera height as Standard, so sea/promenade/rail share y -->
    <rect class="f-sea" y="480" width="1750" height="120" />
    <g class="f-moon night-only">
      <rect x="1290" y="502" width="60" height="3" rx="1.5" opacity="0.35" />
      <rect x="1305" y="530" width="34" height="3" rx="1.5" opacity="0.2" />
      <rect x="1298" y="556" width="44" height="3" rx="1.5" opacity="0.14" />
    </g>
    <rect class="f-ground" y="600" width="1750" height="150" />
    <g class="f-rail" stroke-linecap="round" stroke-width="7">
      <g stroke-width="5">
        <line x1="40" y1="590" x2="40" y2="654" /><line x1="200" y1="590" x2="200" y2="654" />
        <line x1="360" y1="590" x2="360" y2="654" /><line x1="520" y1="590" x2="520" y2="654" />
        <line x1="680" y1="590" x2="680" y2="654" /><line x1="840" y1="590" x2="840" y2="654" />
        <line x1="1000" y1="590" x2="1000" y2="654" /><line x1="1160" y1="590" x2="1160" y2="654" />
        <line x1="1320" y1="590" x2="1320" y2="654" /><line x1="1480" y1="590" x2="1480" y2="654" />
        <line x1="1640" y1="590" x2="1640" y2="654" />
      </g>
      <line x1="0" y1="592" x2="1750" y2="592" />
      <line x1="0" y1="624" x2="1750" y2="624" stroke-width="4" opacity="0.8" />
    </g>
    <HoodedFigure x={FIG.wide.x} y={FIG.wide.y} scale={FIG.wide.scale} />
  </svg>

  <!-- ============ TALL 600×1067 (portrait / mobile) ============ -->
  <svg class="scene scene-tall" viewBox="0 0 600 1067" preserveAspectRatio="xMidYMax slice" role="img"
       aria-label="Cape Town skyline in portrait, by night or day, with a hooded figure on the promenade">
    <rect class="f-sky" width="600" height="1067" />
    <g class="f-star night-only">
      <circle cx="60" cy="80" r="1.6" opacity="0.8" /><circle cx="170" cy="150" r="1.2" opacity="0.5" />
      <circle cx="280" cy="60" r="1.4" opacity="0.7" /><circle cx="90" cy="260" r="1.1" opacity="0.45" />
      <circle cx="350" cy="200" r="1.5" opacity="0.75" /><circle cx="520" cy="270" r="1.3" opacity="0.6" />
      <circle cx="240" cy="320" r="1.1" opacity="0.4" /><circle cx="460" cy="330" r="1.0" opacity="0.35" />
      <circle cx="140" cy="380" r="1.2" opacity="0.5" /><circle cx="560" cy="90" r="1.4" opacity="0.65" />
    </g>
    <g class="night-only">
      <circle class="f-moon" cx="452" cy="200" r="46" />
      <g class="f-crater" opacity="0.55">
        <circle cx="436" cy="186" r="8" /><circle cx="469" cy="214" r="5.5" />
        <circle cx="461" cy="178" r="3.5" /><circle cx="430" cy="216" r="4.5" />
      </g>
    </g>
    <g class="day-only">
      <circle class="f-cel" cx="452" cy="200" r="50" />
      <rect x="60" y="270" width="130" height="20" rx="10" fill="#fff" opacity="0.85" />
      <rect x="300" y="360" width="100" height="18" rx="9" fill="#fff" opacity="0.7" />
    </g>
    <CityScape camera={CAMERA.tall} />
    <!-- portrait carries the extra height as water: further back, more of the bay in view -->
    <rect class="f-sea" y="480" width="600" height="220" />
    <g class="f-moon night-only">
      <rect x="420" y="510" width="56" height="3" rx="1.5" opacity="0.35" />
      <rect x="434" y="548" width="32" height="3" rx="1.5" opacity="0.2" />
      <rect x="426" y="586" width="44" height="3" rx="1.5" opacity="0.14" />
    </g>
    <rect class="f-ground" y="700" width="600" height="367" />
    <g class="f-rail" stroke-linecap="round" stroke-width="7">
      <g stroke-width="5">
        <line x1="30" y1="690" x2="30" y2="756" /><line x1="150" y1="690" x2="150" y2="756" />
        <line x1="270" y1="690" x2="270" y2="756" /><line x1="390" y1="690" x2="390" y2="756" />
        <line x1="510" y1="690" x2="510" y2="756" />
      </g>
      <line x1="0" y1="692" x2="600" y2="692" />
      <line x1="0" y1="726" x2="600" y2="726" stroke-width="4" opacity="0.8" />
    </g>
    <HoodedFigure x={FIG.tall.x} y={FIG.tall.y} scale={FIG.tall.scale} />
  </svg>

  </div><!-- /.camera -->

  <!-- wind: motes on the breeze, deliberately outside .camera so the breeze stays a
       constant speed when the camera pushes in. -->
  <div class="wind" aria-hidden="true">
    <span class="mote" style="top:44%;animation-duration:17s;animation-delay:0s"></span>
    <span class="mote" style="top:62%;animation-duration:21s;animation-delay:-6s;width:4px;height:4px"></span>
    <span class="mote" style="top:53%;animation-duration:14s;animation-delay:-10s;width:6px;height:6px"></span>
    <span class="mote" style="top:73%;animation-duration:24s;animation-delay:-3s;width:4px;height:4px"></span>
    <span class="mote" style="top:35%;animation-duration:19s;animation-delay:-14s"></span>
  </div>

  <!--
    Approach prompt: a real <button> styled as a videogame NPC interaction prompt.
    Hidden by default (revealed by JS on init); JS also hides it after approach.
    Position is approximate right-foreground; JS places it near the measured figure.
  -->
  <button class="approach-prompt" id="approach-prompt" hidden>
    PLACEHOLDER: Approach the hooded figure
  </button>

  <main class="card">
    <div class="card-head">
      <!-- ponytail: abstract placeholder avatar — no likeness guessed -->
      <svg class="avatar" width="64" height="64" viewBox="0 0 64 64" aria-hidden="true">
        <circle cx="32" cy="32" r="32" fill="var(--avatar-ring)" />
        <circle cx="32" cy="34" r="20" fill="var(--mountain)" />
        <g class="eyes">
          <circle cx="25" cy="41" r="2.6" fill="var(--card)" />
          <circle cx="39" cy="41" r="2.6" fill="var(--card)" />
        </g>
        <rect x="18" y="14" width="28" height="16" rx="8" fill="var(--hair)" />
      </svg>
      <span class="name">Caveshen</span>
    </div>
    <!-- Static root content for no-JS path; engine overwrites on init -->
    <p class="stage" id="stage">{root.stage}</p>
    <div aria-live="polite">
      <p class="speech" id="speech">{root.speech}</p>
    </div>
    <ul class="choices" id="choices"></ul>
    <!--
      End dialogue: hidden by default (JS reveals on approach, hides on exit).
      Styled like the .system options. With JS off this stays hidden — no camera
      to exit, so no exit control needed in the no-JS path.
    -->
    <button class="end-dialogue" id="end-dialogue" hidden>PLACEHOLDER: End dialogue ✕</button>
    <noscript>
      <p class="noscript-note">
        <a href="/sheet">Open the character sheet &rarr;</a>
      </p>
    </noscript>
  </main>

  </div><!-- /.stage-frame -->

  <p class="page-foot">PLACEHOLDER — attribution line. All copy is placeholder; the real script is Caveshen's to write.</p>
</Base>

<style is:global>
  /* Night/day layer visibility — driven by :root[data-time] */
  :root[data-time="day"] .night-only          { display: none; }
  :root:not([data-time="day"]) .day-only      { display: none; }

  /* ── P4: stage-frame — a full-height stage, not a letterbox strip ─────────── */
  /* ponytail: stage-frame is position:relative which makes it a positioned element
     that stacks AFTER the toggle (which comes earlier in DOM), so stage-frame's
     bounding box physically covers the toggle area and intercepts its clicks.
     pointer-events:none on stage-frame makes it fully transparent to events;
     interactive children (approach prompt, card) re-enable them individually. */
  .stage-frame {
    position: relative;
    overflow: hidden;
    pointer-events: none;
    max-width: 1200px;
    margin: 1rem auto 0;
    border-radius: 14px;
    border: 1px solid var(--card-edge);
    background: var(--sky);
    aspect-ratio: 1200 / 750;
    transition: background 0.4s ease, border-color 0.4s ease;
  }
  .camera {
    transform-origin: 0 0;
    will-change: transform;
    height: 100%;
    transition: transform 950ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    .camera { transition: none; }
  }

  /* Aspect-ratio scene switching: standard is default; wide/tall take over at the
     extremes. The stage-frame's own aspect-ratio follows the visible scene's viewBox
     so the SVG fills it exactly (no letterboxing, no cropping). */
  .scene { display: block; width: 100%; height: 100%; }
  .scene-wide, .scene-tall { display: none; }
  @media (min-aspect-ratio: 15/8) {
    .stage-frame { aspect-ratio: 1750 / 750; }
    .scene-standard { display: none; }
    .scene-wide { display: block; }
  }
  @media (max-aspect-ratio: 4/5) {
    .stage-frame { aspect-ratio: 600 / 1067; max-width: 480px; }
    .scene-standard { display: none; }
    .scene-tall { display: block; }
  }
  .scene rect, .scene polygon, .scene circle, .scene line, .scene path {
    transition: fill 0.4s ease, stroke 0.4s ease;
  }

  /* ── P4: wind — ambient motes drifting on the breeze ───────────────────────── */
  .wind { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
  .mote {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--mote);
    opacity: 0;
    animation: drift linear infinite;
  }
  @keyframes drift {
    0%   { left: -4%;  opacity: 0; transform: translateY(0); }
    12%  { opacity: var(--mote-op); }
    88%  { opacity: var(--mote-op); }
    100% { left: 104%; opacity: 0; transform: translateY(-38px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .wind { display: none; }
    .mote { animation: none; }
  }

  /* ── P4: approach prompt button ──────────────────────────────────────────── */
  .approach-prompt {
    position: absolute;
    pointer-events: auto; /* re-enable: stage-frame has pointer-events:none */
    /* JS overrides left/top after measuring the visible figure; CSS is fallback */
    right: 10%;
    bottom: 38%;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--text);
    background: rgba(10, 8, 22, 0.55);
    border: 1px solid rgba(233, 226, 207, 0.22);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    cursor: pointer;
    backdrop-filter: blur(3px);
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .approach-prompt:hover,
  .approach-prompt:focus-visible {
    color: var(--btn-hover-text);
    border-color: var(--btn-hover-border);
    background: rgba(10, 8, 22, 0.75);
  }
  .approach-prompt:focus-visible {
    outline: 2px solid var(--btn-hover-border);
    outline-offset: 2px;
  }
  /* Day theme: lighter glass-morphism */
  :root[data-time="day"] .approach-prompt {
    background: rgba(253, 251, 245, 0.65);
    border-color: rgba(37, 48, 56, 0.22);
  }
  :root[data-time="day"] .approach-prompt:hover,
  :root[data-time="day"] .approach-prompt:focus-visible {
    background: rgba(253, 251, 245, 0.88);
  }
  @media (prefers-reduced-motion: reduce) {
    .approach-prompt { transition: none; }
  }

  /* ── P4: end-dialogue button (inside .card; styled like .system options) ── */
  .end-dialogue {
    display: block;
    width: 100%;
    text-align: left;
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--dim);
    background: transparent;
    border: 1.5px dashed var(--option-border);
    border-radius: 999px;
    padding: 0.65rem 1.2rem;
    cursor: pointer;
    margin-top: 0.75rem;
    transition: color 0.12s ease, border-color 0.12s ease;
  }
  .end-dialogue:hover,
  .end-dialogue:focus-visible {
    color: var(--stage);
    border-color: var(--stage);
    background: transparent;
  }
  .end-dialogue:focus-visible {
    outline: 2px solid var(--stage);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .end-dialogue { transition: none; }
  }

  /* ── Dialogue card: an IN-SCENE overlay, not a block below the scene ──────── */
  .card {
    position: absolute;
    left: 50%;
    bottom: 3.5%;
    transform: translateX(-50%);
    width: min(600px, 88%);
    pointer-events: auto; /* re-enable: stage-frame has pointer-events:none */
    padding: 1.75rem 2rem 2rem;
    background: var(--card);
    border: 1px solid var(--card-edge);
    border-radius: 18px;
    box-shadow: var(--card-shadow);
    transition: background 0.4s ease, border-color 0.4s ease;
  }
  .card-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .avatar { flex: none; }
  .avatar circle, .avatar rect { transition: fill 0.4s ease; }
  .avatar .eyes {
    animation: blink 5s infinite;
    transform-origin: center 41px;
  }
  @keyframes blink {
    0%, 92%, 100% { transform: scaleY(1); }
    95%            { transform: scaleY(0.1); }
  }
  .name {
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    background: var(--chip-bg);
    color: var(--chip-text);
    padding: 0.32rem 0.8rem;
    border-radius: 999px;
  }
  .stage {
    font-size: 0.92rem;
    font-style: italic;
    color: var(--stage);
    margin: 0 0 0.75rem;
  }
  .speech {
    font-size: 1.1rem;
    margin: 0 0 1.5rem;
    transition: opacity 0.25s ease;
    min-height: 3.2em;
  }
  .choices {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .choices button {
    display: block;
    width: 100%;
    text-align: left;
    font-family: var(--mono);
    font-size: 0.9rem;
    color: var(--option);
    background: transparent;
    border: 1.5px solid var(--option-border);
    border-radius: 999px;
    padding: 0.65rem 1.2rem;
    cursor: pointer;
    transition: color 0.12s ease, border-color 0.12s ease, background 0.12s ease, transform 0.12s ease;
  }
  .choices button:hover,
  .choices button:focus-visible {
    color: var(--btn-hover-text);
    border-color: var(--btn-hover-border);
    background: var(--btn-hover-bg);
    transform: translateY(-1px);
  }
  .choices button:focus-visible {
    outline: 2px solid var(--btn-hover-border);
    outline-offset: 2px;
  }
  .choices button.system {
    border-style: dashed;
    color: var(--dim);
    font-size: 0.82rem;
  }
  .choices button.system:hover,
  .choices button.system:focus-visible {
    color: var(--stage);
    border-color: var(--stage);
    background: transparent;
  }
  .noscript-note {
    margin-top: 1rem;
    font-family: var(--mono);
    font-size: 0.85rem;
  }
  .noscript-note a { color: var(--option); }
  .page-foot {
    max-width: 620px;
    margin: 2rem auto 2.5rem;
    padding: 0 2rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--dim);
    text-align: center;
  }

  @media (max-width: 680px) {
    .card { padding: 1.4rem 1.3rem 1.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar .eyes { animation: none; }
    body, .scene rect, .scene polygon, .scene circle, .scene line, .scene path,
    .card, .avatar circle, .avatar rect,
    .speech, .choices button { transition: none; }
  }
</style>

<script>
  import { initEngine } from '../scripts/dialogue.js';
  import { computeCameraTransform } from '../scripts/camera.js';
  import tree from '../data/dialogue.json';

  const speechEl    = document.getElementById('speech');
  const stageEl     = document.getElementById('stage');
  const choicesEl   = document.getElementById('choices');
  const card        = document.querySelector('.card') as HTMLElement;
  const camera      = document.querySelector('.camera') as HTMLElement;
  const stageFrame  = document.querySelector('.stage-frame') as HTMLElement;
  const approachBtn = document.getElementById('approach-prompt') as HTMLButtonElement;
  const endDlgBtn   = document.getElementById('end-dialogue') as HTMLButtonElement;

  // ── Dialogue engine ───────────────────────────────────────────────────────

  const render = initEngine(
    tree,
    { speechEl, stageEl, choicesEl },
    (path) => { window.location.href = path; }
  );

  // Initial render is immediate — static content is already in place from SSR.
  render('root', true);

  // ── P4: progressive enhancement — hide card, reveal approach prompt ───────
  // The `hidden` attribute is added here, never in default CSS, so the no-JS
  // path keeps the card visible exactly as before.
  card.hidden = true;
  approachBtn.hidden = false;

  // Position the prompt near the visible figure's measured location in screen space.
  function positionPrompt() {
    const figEl = [...document.querySelectorAll('.hooded-figure')]
      .find((el) => el.getBoundingClientRect().width > 0) as SVGElement | undefined;
    if (!figEl) return;
    const sf  = stageFrame.getBoundingClientRect();
    const fig = figEl.getBoundingClientRect();
    // Centre the button on the figure, ~10% down from the top of the figure
    const left = (fig.left + fig.width  / 2) - sf.left;
    const top  = (fig.top  - sf.top) + fig.height * 0.1;
    approachBtn.style.left      = `${left}px`;
    approachBtn.style.top       = `${top}px`;
    approachBtn.style.right     = 'auto';
    approachBtn.style.bottom    = 'auto';
    approachBtn.style.transform = 'translateX(-50%)';
  }
  positionPrompt();
  window.addEventListener('resize', positionPrompt, { passive: true });

  // ── Camera zoom ───────────────────────────────────────────────────────────

  let approached = false;

  function approach() {
    if (approached) return;
    approached = true;

    // Show card, hide prompt
    card.hidden    = false;
    endDlgBtn.hidden = false;
    approachBtn.hidden = true;

    // Measure the visible figure and compute the camera transform
    const figEl = [...document.querySelectorAll('.hooded-figure')]
      .find((el) => el.getBoundingClientRect().width > 0) as SVGElement | undefined;
    if (figEl) {
      const sf  = stageFrame.getBoundingClientRect();
      const fig = figEl.getBoundingClientRect();
      const scale = 2.2;
      const { tx, ty } = computeCameraTransform({ stage: sf, figure: fig, scale });
      camera.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
    }

    // Focus the first dialogue option (SC5)
    const firstChoice = choicesEl.querySelector('button') as HTMLButtonElement | null;
    firstChoice?.focus();
  }

  function exit() {
    if (!approached) return;
    approached = false;

    // Restore state
    card.hidden    = true;
    endDlgBtn.hidden = true;
    approachBtn.hidden = false;
    camera.style.transform = 'none';

    // Return focus to the approach prompt (SC6)
    approachBtn.focus();
  }

  // ── Event wiring ─────────────────────────────────────────────────────────

  approachBtn.addEventListener('click', approach);
  endDlgBtn.addEventListener('click', exit);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && approached) {
      e.preventDefault();
      exit();
    }
  });
</script>
