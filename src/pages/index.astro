---
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import HoodedFigure from '../components/HoodedFigure.astro';
import tree from '../data/dialogue.json';
const root = tree.root;
---
<Base
  title="The Interview — Caveshen Rajman"
  description="PLACEHOLDER — Caveshen Rajman's interactive portfolio. An adventure-game-styled CV for games industry and tech contacts."
>
  <!-- Toggle: first in DOM so it's first in tab order -->
  <ThemeToggle />

  <!-- stage-frame: overflow:hidden clips the camera zoom; .camera carries the transform -->
  <div class="stage-frame">
  <div class="camera">

  <svg class="scene scene-standard" viewBox="0 0 1200 400" preserveAspectRatio="xMidYMax meet" role="img"
       aria-label="Flat illustration of Table Mountain, Lion's Head and Signal Hill behind the Cape Town city skyline, by night or day">
