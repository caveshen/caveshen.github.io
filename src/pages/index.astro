  </div><!-- /.camera -->

  <!--
    Approach prompt: a real <button> styled as a videogame NPC interaction prompt.
    Hidden by default (revealed by JS on init); JS also hides it after approach.
    Position is approximate right-foreground; JS places it near the measured figure.
  -->
  <button class="approach-prompt" id="approach-prompt" hidden>
    PLACEHOLDER: Approach the hooded figure
  </button>

  </div><!-- /.stage-frame -->

  <main class="card">
    <div class="card-head">
      <!-- ponytail: abstract placeholder avatar — no likeness guessed -->
      <svg class="avatar" width="64" height="64" viewBox="0 0 64 64" aria-hidden="true">
        <circle cx="32" cy="32" r="32" fill="var(--avatar-ring)" />
        <circle cx="32" cy="34" r="20" fill="var(--mountain)" />
        <g class="eyes">
          <circle cx="25" cy="41" r="2.6" fill="var(--card)" />
          <circle cx="39" cy="41" r="2.6" fill="var(--card)" />
        </g>
        <rect x="18" y="14" width="28" height="16" rx="8" fill="var(--hair)" />
      </svg>
      <span class="name">Caveshen</span>
    </div>
    <!-- Static root content for no-JS path; engine overwrites on init -->
    <p class="stage" id="stage">{root.stage}</p>
    <div aria-live="polite">
      <p class="speech" id="speech">{root.speech}</p>
    </div>
    <ul class="choices" id="choices"></ul>
    <!--
      End dialogue: hidden by default (JS reveals on approach, hides on exit).
      Styled like the .system options. With JS off this stays hidden — no camera
      to exit, so no exit control needed in the no-JS path.
    -->
    <button class="end-dialogue" id="end-dialogue" hidden>PLACEHOLDER: End dialogue ✕</button>
    <noscript>
      <p class="noscript-note">
        <a href="/sheet">Open the character sheet &rarr;</a>
      </p>
    </noscript>
  </main>

  <p class="page-foot">PLACEHOLDER — attribution line. All copy is placeholder; the real script is Caveshen's to write.</p>
</Base>

<style is:global>
  /* Night/day layer visibility — driven by :root[data-time] */
  :root[data-time="day"] .night-only          { display: none; }
  :root:not([data-time="day"]) .day-only      { display: none; }

  /* ── P4: stage-frame + camera ────────────────────────────────────────────── */
  /* ponytail: stage-frame is position:relative which makes it a positioned element
     that stacks AFTER the toggle (which comes earlier in DOM), so stage-frame's
     bounding box physically covers the toggle area and intercepts its clicks.
     pointer-events:none on stage-frame makes it fully transparent to events;
     .approach-prompt re-enables them only where the interactive button lives. */
  .stage-frame {
    position: relative;
    overflow: hidden;
    pointer-events: none;
  }
  .camera {
    transform-origin: 0 0;
    will-change: transform;
    transition: transform 950ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    .camera { transition: none; }
  }

  /* ── P4: approach prompt button ──────────────────────────────────────────── */
  .approach-prompt {
    position: absolute;
    pointer-events: auto; /* re-enable: stage-frame has pointer-events:none */
    /* JS overrides left/top after measuring the visible figure; CSS is fallback */
    right: 10%;
    bottom: 38%;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--text);
    background: rgba(10, 8, 22, 0.55);
    border: 1px solid rgba(233, 226, 207, 0.22);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    cursor: pointer;
    backdrop-filter: blur(3px);
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .approach-prompt:hover,
  .approach-prompt:focus-visible {
    color: var(--btn-hover-text);
    border-color: var(--btn-hover-border);
    background: rgba(10, 8, 22, 0.75);
  }
  .approach-prompt:focus-visible {
    outline: 2px solid var(--btn-hover-border);
    outline-offset: 2px;
  }
  /* Day theme: lighter glass-morphism */
  :root[data-time="day"] .approach-prompt {
    background: rgba(253, 251, 245, 0.65);
    border-color: rgba(37, 48, 56, 0.22);
  }
  :root[data-time="day"] .approach-prompt:hover,
  :root[data-time="day"] .approach-prompt:focus-visible {
    background: rgba(253, 251, 245, 0.88);
  }
  @media (prefers-reduced-motion: reduce) {
    .approach-prompt { transition: none; }
  }

  /* ── P4: end-dialogue button (inside .card; styled like .system options) ── */
  .end-dialogue {
    display: block;
    width: 100%;
    text-align: left;
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--dim);
    background: transparent;
    border: 1.5px dashed var(--option-border);
    border-radius: 999px;
    padding: 0.65rem 1.2rem;
    cursor: pointer;
    margin-top: 0.75rem;
    transition: color 0.12s ease, border-color 0.12s ease;
  }
  .end-dialogue:hover,
  .end-dialogue:focus-visible {
    color: var(--stage);
    border-color: var(--stage);
    background: transparent;
  }
  .end-dialogue:focus-visible {
    outline: 2px solid var(--stage);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .end-dialogue { transition: none; }
  }

  /* Scene SVG */
  .scene {
    display: block;
    width: 100%;
    height: clamp(220px, 38vh, 380px);
    /* gradient continues sky/sea bands at letterbox edges (meet never crops) */
    background: linear-gradient(to bottom, var(--sky) 0% 88%, var(--sea) 88% 100%);
  }
  .scene rect, .scene polygon, .scene circle {
    transition: fill 0.4s ease;
  }

  /* Aspect-ratio scene switching: standard is default; wide/tall take over at the extremes */
  .scene-wide, .scene-tall { display: none; }
  @media (min-aspect-ratio: 15/8) {
    .scene-standard { display: none; }
    .scene-wide { display: block; }
  }
  @media (max-aspect-ratio: 4/5) {
    .scene-standard { display: none; }
    .scene-tall {
      display: block;
      height: clamp(320px, 52vh, 560px);
      /* tall artwork's sea line is 700/800 = 87.5%, vs 88% for the others */
      background: linear-gradient(to bottom, var(--sky) 0% 87.5%, var(--sea) 87.5% 100%);
    }
  }

  /* Dialogue card */
  .card {
    max-width: 620px;
    margin: -72px auto 0;
    padding: 1.75rem 2rem 2rem;
    background: var(--card);
    border: 1px solid var(--card-edge);
    border-radius: 18px;
    box-shadow: var(--card-shadow);
    position: relative;
    transition: background 0.4s ease, border-color 0.4s ease;
  }
  .card-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .avatar { flex: none; }
  .avatar circle, .avatar rect { transition: fill 0.4s ease; }
  .avatar .eyes {
    animation: blink 5s infinite;
    transform-origin: center 41px;
  }
  @keyframes blink {
    0%, 92%, 100% { transform: scaleY(1); }
    95%            { transform: scaleY(0.1); }
  }
  .name {
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    background: var(--chip-bg);
    color: var(--chip-text);
    padding: 0.32rem 0.8rem;
    border-radius: 999px;
  }
  .stage {
    font-size: 0.92rem;
    font-style: italic;
    color: var(--stage);
    margin: 0 0 0.75rem;
  }
  .speech {
    font-size: 1.1rem;
    margin: 0 0 1.5rem;
    transition: opacity 0.25s ease;
    min-height: 3.2em;
  }
  .choices {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .choices button {
    display: block;
    width: 100%;
    text-align: left;
    font-family: var(--mono);
    font-size: 0.9rem;
    color: var(--option);
    background: transparent;
    border: 1.5px solid var(--option-border);
    border-radius: 999px;
    padding: 0.65rem 1.2rem;
    cursor: pointer;
    transition: color 0.12s ease, border-color 0.12s ease, background 0.12s ease, transform 0.12s ease;
  }
  .choices button:hover,
  .choices button:focus-visible {
    color: var(--btn-hover-text);
    border-color: var(--btn-hover-border);
    background: var(--btn-hover-bg);
    transform: translateY(-1px);
  }
  .choices button:focus-visible {
    outline: 2px solid var(--btn-hover-border);
    outline-offset: 2px;
  }
  .choices button.system {
    border-style: dashed;
    color: var(--dim);
    font-size: 0.82rem;
  }
  .choices button.system:hover,
  .choices button.system:focus-visible {
    color: var(--stage);
    border-color: var(--stage);
    background: transparent;
  }
  .noscript-note {
    margin-top: 1rem;
    font-family: var(--mono);
    font-size: 0.85rem;
  }
  .noscript-note a { color: var(--option); }
  .page-foot {
    max-width: 620px;
    margin: 2rem auto 2.5rem;
    padding: 0 2rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--dim);
    text-align: center;
  }

  @media (max-width: 680px) {
    .card { margin: 0.75rem 1rem 0; padding: 1.4rem 1.3rem 1.5rem; }
  }

  /* portrait aspect: card sits below the scene, never over it (after .card base so it wins) */
  @media (max-aspect-ratio: 4/5) {
    .card { margin: 0.75rem auto 0; width: calc(100% - 2rem); }
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar .eyes { animation: none; }
    body, .scene rect, .scene polygon, .scene circle,
    .card, .avatar circle, .avatar rect,
    .speech, .choices button { transition: none; }
  }
</style>

<script>
  import { initEngine } from '../scripts/dialogue.js';
  import { computeCameraTransform } from '../scripts/camera.js';
  import tree from '../data/dialogue.json';

  const speechEl    = document.getElementById('speech');
  const stageEl     = document.getElementById('stage');
  const choicesEl   = document.getElementById('choices');
  const card        = document.querySelector('.card') as HTMLElement;
  const camera      = document.querySelector('.camera') as HTMLElement;
  const stageFrame  = document.querySelector('.stage-frame') as HTMLElement;
  const approachBtn = document.getElementById('approach-prompt') as HTMLButtonElement;
  const endDlgBtn   = document.getElementById('end-dialogue') as HTMLButtonElement;

  // ── Dialogue engine ───────────────────────────────────────────────────────

  const render = initEngine(
    tree,
    { speechEl, stageEl, choicesEl },
    (path) => { window.location.href = path; }
  );

  // Initial render is immediate — static content is already in place from SSR.
  render('root', true);

  // ── P4: progressive enhancement — hide card, reveal approach prompt ───────
  // The `hidden` attribute is added here, never in default CSS, so the no-JS
  // path keeps the card visible exactly as before.
  card.hidden = true;
  approachBtn.hidden = false;

  // Position the prompt near the visible figure's measured location in screen space.
  function positionPrompt() {
    const figEl = [...document.querySelectorAll('.hooded-figure')]
      .find((el) => el.getBoundingClientRect().width > 0) as SVGElement | undefined;
    if (!figEl) return;
    const sf  = stageFrame.getBoundingClientRect();
    const fig = figEl.getBoundingClientRect();
    // Centre the button on the figure, ~10% down from the top of the figure
    const left = (fig.left + fig.width  / 2) - sf.left;
    const top  = (fig.top  - sf.top) + fig.height * 0.1;
    approachBtn.style.left      = `${left}px`;
    approachBtn.style.top       = `${top}px`;
    approachBtn.style.right     = 'auto';
    approachBtn.style.bottom    = 'auto';
    approachBtn.style.transform = 'translateX(-50%)';
  }
  positionPrompt();
  window.addEventListener('resize', positionPrompt, { passive: true });

  // ── Camera zoom ───────────────────────────────────────────────────────────

  let approached = false;

  function approach() {
    if (approached) return;
    approached = true;

    // Show card, hide prompt
    card.hidden    = false;
    endDlgBtn.hidden = false;
    approachBtn.hidden = true;

    // Measure the visible figure and compute the camera transform
    const figEl = [...document.querySelectorAll('.hooded-figure')]
      .find((el) => el.getBoundingClientRect().width > 0) as SVGElement | undefined;
    if (figEl) {
      const sf  = stageFrame.getBoundingClientRect();
      const fig = figEl.getBoundingClientRect();
      const scale = 2.2;
      const { tx, ty } = computeCameraTransform({ stage: sf, figure: fig, scale });
      camera.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
    }

    // Focus the first dialogue option (SC5)
    const firstChoice = choicesEl.querySelector('button') as HTMLButtonElement | null;
    firstChoice?.focus();
  }

  function exit() {
    if (!approached) return;
    approached = false;

    // Restore state
    card.hidden    = true;
    endDlgBtn.hidden = true;
    approachBtn.hidden = false;
    camera.style.transform = 'none';

    // Return focus to the approach prompt (SC6)
    approachBtn.focus();
  }

  // ── Event wiring ─────────────────────────────────────────────────────────

  approachBtn.addEventListener('click', approach);
  endDlgBtn.addEventListener('click', exit);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && approached) {
      e.preventDefault();
      exit();
    }
  });
</script>
