---
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
---
<Base
  title="Character Sheet — Caveshen Rajman"
  description="PLACEHOLDER — Caveshen Rajman's RPG-flavoured CV: Engineering Manager, skills, quest log, and achievements."
>
  <ThemeToggle />

  <main class="sheet-wrap">

    <!-- ── Nameplate banner ────────────────────────────────── -->
    <header class="nameplate">
      <nav class="sheet-nav">
        <a href="/" class="back-link">&#8592; Back to the interview</a>
        <a href="/cv.pdf" class="download-btn">&#11015; Download Character Sheet</a>
      </nav>
      <div class="nameplate-inner">
        <div class="name-box">
          <h1>Caveshen Rajman</h1>
          <!-- his authored LinkedIn headline, not invented copy -->
          <p class="epithet">Problem solver, coffee enjoyer, 10x human</p>
          <p class="player-caption">Character Name</p>
        </div>
        <div class="id-grid">
          <div class="id-field">
            <!-- PLACEHOLDER: Class & Level — scores are illustrative; Caveshen tunes -->
            <p class="value">Engineering Manager <em>11</em></p>
            <p class="label">Class &amp; Level</p>
          </div>
          <div class="id-field">
            <p class="value">Software Engineering</p>
            <p class="label">Background</p>
          </div>
          <div class="id-field">
            <p class="value">Cape Town, South Africa</p>
            <p class="label">Home Region</p>
          </div>
          <div class="id-field">
            <!-- PLACEHOLDER: Caveshen's alignment flavour -->
            <p class="value">PLACEHOLDER</p>
            <p class="label">Alignment</p>
          </div>
          <div class="id-field xp-bar">
            <div class="xp-track"><div class="xp-fill"></div></div>
            <p class="label">Experience &mdash; 11 years in tech &middot; levelling since 2015</p>
          </div>
        </div>
      </div>
    </header>

    <!-- ── Main grid ───────────────────────────────────────── -->
    <div class="sheet-grid">

      <!-- Left rail: ability scores -->
      <section class="abilities-col" aria-label="Ability scores">
        <!-- PLACEHOLDER: scores and wording; Caveshen to tune -->
        <div class="ability"><p class="ab-name">People</p><p class="ab-score">17</p><span class="ab-mod">+3</span></div>
        <div class="ability"><p class="ab-name">Tech</p><p class="ab-score">16</p><span class="ab-mod">+3</span></div>
        <div class="ability"><p class="ab-name">Product</p><p class="ab-score">14</p><span class="ab-mod">+2</span></div>
        <div class="ability"><p class="ab-name">Delivery</p><p class="ab-score">16</p><span class="ab-mod">+3</span></div>
        <div class="ability"><p class="ab-name">Narrative</p><p class="ab-score">13</p><span class="ab-mod">+1</span></div>
        <div class="ability"><p class="ab-name">Strategy</p><p class="ab-score">15</p><span class="ab-mod">+2</span></div>
      </section>

      <!-- Middle column -->
      <div class="middle-col">

        <!-- Skills panel -->
        <section class="panel" aria-labelledby="skills-caption">
          <ul class="skill-list">
            <!-- PLACEHOLDER: skills list; Caveshen to replace with real list -->
            <li><span class="dot expert"></span><span class="skill-mod">+6</span><span class="skill-name">Mentoring</span><span class="skill-attr">(People)</span></li>
            <li><span class="dot prof"></span><span class="skill-mod">+5</span><span class="skill-name">Team Building</span><span class="skill-attr">(People)</span></li>
            <li><span class="dot prof"></span><span class="skill-mod">+5</span><span class="skill-name">Stakeholder Diplomacy</span><span class="skill-attr">(People)</span></li>
            <li><span class="dot expert"></span><span class="skill-mod">+6</span><span class="skill-name">C# Systems</span><span class="skill-attr">(Tech)</span></li>
            <li><span class="dot prof"></span><span class="skill-mod">+5</span><span class="skill-name">SQL Archaeology</span><span class="skill-attr">(Tech)</span></li>
            <li><span class="dot prof"></span><span class="skill-mod">+4</span><span class="skill-name">Roadmapping</span><span class="skill-attr">(Product)</span></li>
            <li><span class="dot prof"></span><span class="skill-mod">+4</span><span class="skill-name">Scope Wrangling</span><span class="skill-attr">(Delivery)</span></li>
            <li><span class="dot prof"></span><span class="skill-mod">+4</span><span class="skill-name">Games Journalism</span><span class="skill-attr">(Narrative)</span></li>
            <li><span class="dot"></span><span class="skill-mod">+1</span><span class="skill-name">Dialogue Writing</span><span class="skill-attr">(Narrative)</span></li>
            <li><span class="dot"></span><span class="skill-mod">+1</span><span class="skill-name">Worldbuilding</span><span class="skill-attr">(Narrative)</span></li>
          </ul>
          <div class="skill-key">
            <span><span class="dot expert key-dot"></span>expertise</span>
            <span><span class="dot prof key-dot"></span>proficient</span>
            <span><span class="dot key-dot"></span>learning</span>
          </div>
          <p class="panel-caption" id="skills-caption">Skills</p>
        </section>

        <!-- Spellbook panel -->
        <!-- spell tier assignments are Caveshen's to tune -->
        <section class="panel" aria-labelledby="spellbook-caption">
          <div class="spell-tier">
            <div class="tier-head"><span class="tier-badge">0</span> Cantrips <span class="slots">&middot; at will</span></div>
            <div class="spell-row">
              <span class="spell">.NET / C#</span><span class="spell">SQL</span><span class="spell">JavaScript</span><span class="spell">Git</span>
            </div>
          </div>
          <div class="spell-tier">
            <div class="tier-head"><span class="tier-badge">1</span> First Level <span class="slots">&middot; &#9689;&#9689;&#9689;&#9675; slots</span></div>
            <div class="spell-row">
              <span class="spell">VueJS</span><span class="spell">React</span><span class="spell">Angular</span><span class="spell">GraphQL</span><span class="spell">Spring</span>
            </div>
          </div>
          <div class="spell-tier">
            <div class="tier-head"><span class="tier-badge">2</span> Second Level <span class="slots">&middot; &#9689;&#9689;&#9675; slots</span></div>
            <div class="spell-row">
              <span class="spell">Azure</span><span class="spell">AWS</span><span class="spell">Power BI</span>
            </div>
          </div>
          <!-- tier name and joke note are Caveshen's to tune -->
          <div class="spell-tier last-tier">
            <div class="tier-head"><span class="tier-badge">&#9670;</span> Divination <span class="slots">&middot; the school of finding hidden truths</span></div>
            <div class="spell-row">
              <span class="spell">Cypress</span><span class="spell">Selenium</span><span class="spell">K6</span><span class="spell">NUnit</span><span class="spell">XUnit</span><span class="spell">WebDriverIO</span>
            </div>
          </div>
          <p class="panel-caption" id="spellbook-caption">Spellbook &mdash; Tech Stack</p>
        </section>

      </div>

      <!-- Right column -->
      <div class="right-col">

        <!-- Quest Log panel -->
        <section class="panel" aria-labelledby="questlog-caption">
          <article class="quest">
            <h3>Engineering Manager &mdash; Derivco Cape Town</h3>
            <p class="q-meta">JUNE 2024 &mdash; PRESENT &middot; PLACEHOLDER</p>
            <!-- PLACEHOLDER: flavour line in Caveshen's voice -->
            <p>PLACEHOLDER &mdash; <em>the current campaign.</em></p>
          </article>
          <article class="quest">
            <h3>Senior Software Engineer, Project Lead &mdash; Entelect</h3>
            <p class="q-meta">APRIL 2022 &mdash; MAY 2024 &middot; PLACEHOLDER</p>
            <!-- PLACEHOLDER: flavour line -->
            <p>PLACEHOLDER &mdash; consulting arc; many parties, many dungeons.</p>
          </article>
          <article class="quest">
            <h3>Senior Software Developer (Technical Lead) &mdash; Derivco Durban</h3>
            <p class="q-meta">JANUARY 2015 &mdash; MARCH 2022 &middot; PLACEHOLDER</p>
            <!-- PLACEHOLDER: flavour line; e.g. "Tester → Tech Lead — origin story" -->
            <p>PLACEHOLDER &mdash; where the character was rolled.</p>
          </article>
          <article class="quest">
            <h3>Managing Editor &mdash; EGMR</h3>
            <p class="q-meta">FEBRUARY 2011 &mdash; DECEMBER 2015 &middot; PLACEHOLDER</p>
            <!-- PLACEHOLDER: Caveshen writes the flavour line for the games-media arc -->
            <p>PLACEHOLDER &mdash; the games-media arc; column, podcasts, press badges.</p>
          </article>
          <p class="panel-caption" id="questlog-caption">Backstory &mdash; Quest Log</p>
        </section>

        <!-- Features & Traits panel -->
        <section class="panel" aria-labelledby="feats-caption">
          <ul class="feat-list">
            <!-- PLACEHOLDER: Education & Training; Caveshen to fill -->
            <li><span class="feat-mark">&#10022;</span><span class="feat-body"><strong>Bachelor of Commerce, Information Systems &amp; Technology</strong> &mdash; University of KwaZulu-Natal, Durban &middot; 2014.</span></li>
            <li><span class="feat-mark">&#10022;</span><span class="feat-body"><strong>Certified Tester, Foundation Level (ISTQB)</strong> &mdash; 2015.</span></li>
            <li><span class="feat-mark">&#10022;</span><span class="feat-body"><strong>PLACEHOLDER: Training</strong> &mdash; Crucial Conversations, Personal Mastery, Legitimate Leadership.</span></li>
          </ul>
          <p class="panel-caption" id="feats-caption">Features &amp; Traits &mdash; Education &amp; Training</p>
        </section>

      </div>
    </div>

    <!-- Contact footer -->
    <footer class="sheet-foot">
      <a href="https://www.linkedin.com/in/caveshen" class="contact-link">LinkedIn</a>
      <a href="https://github.com/caveshen" class="contact-link">GitHub</a>
    </footer>

  </main>
</Base>

<style is:global>
  /* Sheet-scoped nebular background (PRD §4 round 6); / keeps plain --bg */
  body { background: var(--sheet-bg); }

  /* AMOLED night tone-shift (PRD §4 round 7): retire the purple on this
     page only — bluer edges, blue-grey dim, black-blue grounds. Day resets
     below keep the approved round-6 day values byte-identical. */
  body {
    --card-edge: #1f2942;
    --dim: #94a2c6;
    --bg: #0a0d16;
  }
  [data-time="day"] body {
    --card-edge: rgba(37, 48, 56, 0.12);
    --dim: #4d6260;
    --bg: #e9f0ee;
  }

  /* ── sheet wrapper ──────────────────────────────────────── */
  .sheet-wrap {
    max-width: 1080px;
    margin: 0 auto;
    padding: 1.75rem 1.25rem 4rem;
  }

  /* ── panel convention: bordered card, caption BELOW ─────── */
  .panel {
    background: var(--panel-grad);
    border: 1px solid var(--card-edge);
    border-radius: 10px;
    padding: 1.4rem 1.45rem 1rem;
    display: flex;
    flex-direction: column;
    transition: border-color 0.4s ease;
  }
  .panel-caption {
    font-family: var(--mono);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--stage);
    text-align: center;
    margin-top: auto;
    padding-top: 1rem;
  }

  /* ── nameplate banner ───────────────────────────────────── */
  .nameplate { margin-bottom: 1.25rem; }

  .sheet-nav {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 0.9rem;
  }

  .nameplate-inner {
    display: grid;
    grid-template-columns: minmax(200px, 1fr) 2fr;
    gap: 0.9rem;
  }

  .name-box {
    background: var(--panel-grad);
    border: 1px solid var(--card-edge);
    border-radius: 10px;
    padding: 1.5rem 1.4rem 1.1rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition: border-color 0.4s ease;
  }
  .name-box h1 {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 700;
    letter-spacing: 0.01em;
    line-height: 1.2;
  }
  .epithet {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--dim);
    margin-top: 0.4rem;
  }
  .player-caption {
    font-family: var(--mono);
    font-size: 0.58rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--stage);
    margin-top: 0.75rem;
  }

  .id-grid {
    background: var(--panel-grad);
    border: 1px solid var(--card-edge);
    border-radius: 10px;
    padding: 1.25rem 1.4rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem 1.4rem;
    transition: border-color 0.4s ease;
  }
  .id-field .value {
    font-family: var(--serif);
    font-size: 0.92rem;
    line-height: 1.3;
  }
  .id-field .value em {
    color: var(--option);
    font-style: normal;
  }
  .id-field .label {
    font-family: var(--mono);
    font-size: 0.54rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--stage);
    margin-top: 0.25rem;
    border-top: 1px solid var(--card-edge);
    padding-top: 0.25rem;
  }
  .xp-bar { grid-column: 2 / -1; }
  .xp-track {
    height: 7px;
    background: var(--bg);
    border: 1px solid var(--card-edge);
    border-radius: 999px;
    overflow: hidden;
  }
  .xp-fill { width: 78%; height: 100%; background: var(--celestial); border-radius: 999px; }

  /* ── main grid ──────────────────────────────────────────── */
  .sheet-grid {
    display: grid;
    grid-template-columns: 118px 1.2fr 1.4fr;
    gap: 1.4rem;
    align-items: start;
  }
  .middle-col, .right-col {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  /* ── ability scores rail ────────────────────────────────── */
  .abilities-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .ability {
    background: var(--panel-grad);
    border: 1px solid var(--card-edge);
    border-radius: 12px;
    padding: 0.85rem 0.4rem 1.15rem;
    text-align: center;
    position: relative;
    transition: border-color 0.4s ease;
  }
  .ab-name {
    font-family: var(--mono);
    font-size: 0.52rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--stage);
  }
  .ab-score {
    font-family: var(--serif);
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.1;
    margin-top: 0.15rem;
    font-variant-numeric: tabular-nums;
  }
  .ab-mod {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: -0.6rem;
    background: var(--bg);
    color: var(--option);
    border: 1px solid var(--option-border);
    border-radius: 999px;
    font-family: var(--mono);
    font-size: 0.63rem;
    font-weight: 600;
    padding: 0.1rem 0.45rem;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* ── skills ─────────────────────────────────────────────── */
  .skill-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .skill-list li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--mono);
    font-size: 0.78rem;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid var(--option);
    flex: none;
  }
  .dot.prof { background: var(--option); }
  .dot.expert { background: var(--celestial); border-color: var(--celestial); }
  .skill-mod { color: var(--option); font-weight: 600; min-width: 2.2ch; font-variant-numeric: tabular-nums; }
  .skill-name { color: var(--text); }
  .skill-attr { color: var(--stage); font-size: 0.64rem; }
  .skill-key {
    font-family: var(--mono);
    font-size: 0.58rem;
    color: var(--dim);
    margin-top: 0.7rem;
    display: flex;
    gap: 0.9rem;
    align-items: center;
  }
  .key-dot { width: 7px; height: 7px; display: inline-block; vertical-align: middle; margin-right: 4px; }

  /* ── spellbook ──────────────────────────────────────────── */
  .spell-tier { margin-bottom: 1.1rem; }
  .spell-tier.last-tier { margin-bottom: 0; }
  .tier-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--option);
    margin-bottom: 0.5rem;
  }
  .tier-badge {
    border: 1px solid var(--option-border);
    border-radius: 5px;
    padding: 0.04rem 0.32rem;
    font-size: 0.68rem;
    color: var(--text);
  }
  .slots { color: var(--stage); letter-spacing: 0.04em; text-transform: none; }
  .spell-row { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .spell {
    font-family: var(--mono);
    font-size: 0.72rem;
    border: 1px solid var(--option-border);
    border-radius: 999px;
    padding: 0.24rem 0.7rem;
    color: var(--text);
  }
  /* ── quest log ──────────────────────────────────────────── */
  .quest {
    padding: 1rem 0;
    border-top: 1px solid var(--card-edge);
  }
  .quest:first-of-type { border-top: none; padding-top: 0.1rem; }
  .quest h3 { font-family: var(--serif); font-size: 1rem; font-weight: 700; }
  .q-meta {
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--stage);
    letter-spacing: 0.05em;
    margin: 0.25rem 0 0.4rem;
  }
  .quest p { font-size: 0.84rem; line-height: 1.6; color: var(--dim); }
  .quest p em { color: var(--text); font-style: italic; }

  /* ── features & traits ──────────────────────────────────── */
  .feat-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .feat-list li { display: flex; gap: 0.6rem; font-size: 0.84rem; line-height: 1.55; }
  .feat-mark { color: var(--celestial); font-family: var(--mono); flex: none; }
  .feat-body { color: var(--dim); }
  .feat-body strong { color: var(--text); font-weight: 700; }

  /* ── nav / download / contact ───────────────────────────── */
  .back-link {
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--stage);
    text-decoration: none;
    border: 1px dashed var(--card-edge);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    transition: color 0.12s ease, border-color 0.12s ease;
  }
  .back-link:hover, .back-link:focus-visible {
    color: var(--text);
    border-color: var(--stage);
  }
  .back-link:focus-visible { outline: 2px solid var(--celestial); outline-offset: 2px; }

  .download-btn {
    font-family: var(--mono);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--chip-text);
    background: var(--celestial);
    border: 1.5px solid var(--celestial);
    border-radius: 999px;
    padding: 0.5rem 1.2rem;
    text-decoration: none;
    transition: opacity 0.12s ease;
  }
  .download-btn:hover, .download-btn:focus-visible { opacity: 0.82; }
  .download-btn:focus-visible { outline: 2px solid var(--text); outline-offset: 2px; }

  .sheet-foot {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .contact-link {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--option);
    text-decoration: none;
    border-bottom: 1px dotted var(--option-border);
    padding-bottom: 1px;
    transition: color 0.12s ease, border-color 0.12s ease;
  }
  .contact-link:hover, .contact-link:focus-visible {
    color: var(--celestial);
    border-color: var(--celestial);
  }
  .contact-link:focus-visible { outline: 2px solid var(--celestial); outline-offset: 2px; }

  /* ── desktop height-alignment: right col sets height; middle last panel grows to meet it; rail stays natural ── */
  @media (min-width: 901px) {
    .sheet-grid { align-items: stretch; }
    .abilities-col { align-self: start; }
    .middle-col .panel:last-child { flex: 1; }
  }

  /* ── responsive ─────────────────────────────────────────── */
  @media (max-width: 900px) {
    .sheet-grid { grid-template-columns: 110px 1fr; }
    .right-col { grid-column: 1 / -1; }
  }
  @media (max-width: 640px) {
    .nameplate-inner { grid-template-columns: 1fr; }
    .id-grid { grid-template-columns: 1fr 1fr; }
    .xp-bar { grid-column: 1 / -1; }
    .sheet-grid { grid-template-columns: 1fr; }
    .abilities-col { flex-direction: row; flex-wrap: wrap; }
    .ability { flex: 1 1 80px; }
  }

  /* ── reduced motion ─────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .panel, .name-box, .id-grid, .ability,
    .back-link, .download-btn, .contact-link { transition: none; }
  }
</style>
