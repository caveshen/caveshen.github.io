---
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
---
<Base title="Character Sheet — Caveshen Rajman">
  <ThemeToggle />

  <header class="sheet-banner">
    <div class="sheet-banner-inner">
      <h1 class="char-name">Caveshen Rajman</h1>
      <p class="char-class">PLACEHOLDER: class line (e.g. "Engineering Manager, multiclassing in Narrative Design")</p>
      <a href="/cv.pdf" class="download-btn">&#11015; Download Character Sheet</a>
    </div>
  </header>

  <main class="sheet-main">

    <!-- Skills -->
    <section class="panel" aria-labelledby="skills-heading">
      <h2 id="skills-heading">Skills</h2>
      <div class="skill-groups">
        <div class="skill-group">
          <h3>People</h3>
          <ul class="skill-list">
            <li>Stakeholder Management</li>
            <li>Coaching and Mentoring</li>
            <li>Change Management</li>
            <li>Strategic Decision-making</li>
          </ul>
        </div>
        <div class="skill-group">
          <h3>Product</h3>
          <ul class="skill-list">
            <li>Project Management</li>
            <li>Systems Analysis and Design</li>
            <li>Technical Documentation</li>
            <li>Outcomes-based Delivery</li>
          </ul>
        </div>
        <div class="skill-group">
          <h3>Tech</h3>
          <ul class="skill-list">
            <li>VueJS</li>
            <li>React</li>
            <li>Angular</li>
            <li>.NET</li>
            <li>Spring</li>
            <li>GraphQL</li>
            <li>Azure</li>
            <li>AWS</li>
            <li>Power BI</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Quest Log -->
    <section class="panel" aria-labelledby="quest-heading">
      <h2 id="quest-heading">Quest Log</h2>

      <article class="quest">
        <div class="quest-header">
          <h3>Software Engineering Manager</h3>
          <span class="quest-meta">Derivco &middot; Cape Town &middot; June 2024&ndash;Present</span>
        </div>
        <p>Leading two high-performance, high-functioning full-stack software development
        teams responsible for two core path flows within the company: the Player
        Account Management product suite and the Player Balance Ledger product suite.</p>
        <ul>
          <li>Full end-to-end ownership from ideation to roadmap to delivery to support</li>
          <li>High throughput, processing 100+ billion requests per month</li>
          <li>High reliability, observability, and security</li>
          <li>The backbone of many core flows with 99.98% uptime</li>
          <li>Fully compliant with EUGDPR, ISO27001, and other relevant regulations</li>
        </ul>
        <p>In this role I wear many hats including Business Analysis, Product Management,
        Software Engineering, DevOps, Quality Assurance, Automation, and Project
        Management. I have also led teams leveraging AI initiatives to improve
        turnaround time and software quality, including developing key organisational tools:</p>
        <ul>
          <li>AI assistant integrating Azure and ITSM tooling to provide change and
          release details to auditors</li>
          <li>Automated change management product orchestrating ITSM processes using
          Azure pipelines</li>
          <li>Automated support service for processing and resolving customer tickets</li>
        </ul>
      </article>

      <article class="quest">
        <div class="quest-header">
          <h3>Senior Software Engineer &mdash; Project Lead</h3>
          <span class="quest-meta">Entelect &middot; Cape Town &middot; April 2022&ndash;May 2024</span>
        </div>
        <p>Software consultancy position providing technical expertise, leadership, and
        stakeholder management for eBay Mexico, Adevinta, FNZ UK, and MunichRe Insurance.</p>
        <ul>
          <li>Acting Team Lead at eBay Mexico, Adevinta, and FNZ UK: performance
          management, product management, software analysis and design, and
          stakeholder reporting</li>
          <li>Project Lead at MunichRe, combining Team Lead and Senior Engineer duties:
          performance, product, and stakeholder management, coaching, and reviews</li>
          <li>Spent 80% of my time designing, developing, testing, deploying, and
          supporting software products, primarily within the insurance sector</li>
          <li>Delivered new features, bug fixes, technical-debt reduction, and new
          architecture to improve performance on existing systems</li>
          <li>Assisted with compliance and governance processes, software documentation,
          creation and enforcement of agile and SDLC lifecycles, and change management</li>
        </ul>
      </article>

      <article class="quest">
        <div class="quest-header">
          <h3>Senior Software Developer (Technical Lead)</h3>
          <span class="quest-meta">Derivco &middot; Durban &middot; January 2015&ndash;March 2022</span>
        </div>
        <p>Technical Lead within the Quickfire BackOffice department, responsible for
        large-scale, high-performance campaign creation and tracking tools,
        collaborating across four geographic locations with four teams of thirty
        people in total.</p>
        <ul>
          <li>Progressed from Production Tester to Developer to Technical Lead</li>
          <li>Worked with architects on high-level architecture for campaign-based
          products, following an IDesign approach to encapsulate the volatility of
          downstream dependencies (microservices)</li>
          <li>Founded the Campaign Manager Design Board, with developers from each team,
          to improve technical discussion and decision-making across the SDLC</li>
          <li>Responsible for Work Breakdown Structure creation, Epic and Feature
          creation on Azure DevOps, and outcomes-based delivery and reporting</li>
          <li>Responsible for stakeholder and change management: project status, risks,
          blockers and mitigation, prioritisation, and delegation</li>
          <li>Documented all strategies: naming conventions, branching and merging,
          automation-first testing focused on Test-Driven Design, monitoring,
          compliance, and feature flagging</li>
        </ul>
      </article>
    </section>

    <!-- Achievements -->
    <section class="panel" aria-labelledby="achievements-heading">
      <h2 id="achievements-heading">Achievements</h2>
      <ul class="achievement-list">
        <li>
          <span class="achievement-name">Bachelor of Commerce, Information Systems &amp; Technology</span>
          <span class="achievement-meta">University of KwaZulu-Natal, Durban &middot; 2014</span>
        </li>
        <li>
          <span class="achievement-name">Certified Tester, Foundation Level (ISTQB)</span>
          <span class="achievement-meta">2015</span>
        </li>
        <li>
          <span class="achievement-name">Crucial Conversations</span>
          <span class="achievement-meta">Derivco &middot; 2018</span>
        </li>
        <li>
          <span class="achievement-name">Personal Mastery</span>
          <span class="achievement-meta">Derivco &middot; 2019</span>
        </li>
        <li>
          <span class="achievement-name">Legitimate Leadership</span>
          <span class="achievement-meta">Entelect &middot; 2024</span>
        </li>
      </ul>
    </section>

    <!-- Contact -->
    <section class="panel" aria-labelledby="contact-heading">
      <h2 id="contact-heading">Contact</h2>
      <ul class="contact-list">
        <li><a href="https://www.linkedin.com/in/caveshen" class="contact-link">LinkedIn</a></li>
        <li><a href="https://github.com/caveshen" class="contact-link">GitHub</a></li>
      </ul>
    </section>

  </main>

  <p class="sheet-foot">PLACEHOLDER — flavour footer. Caveshen writes the real version.</p>
</Base>

<style is:global>
  /* ── /sheet layout ─────────────────────────────────────────────── */
  .sheet-banner {
    background: var(--card);
    border-bottom: 2px solid var(--card-edge);
    padding: 3.5rem 2rem 2rem;
    text-align: center;
    transition: background 0.4s ease, border-color 0.4s ease;
  }
  .sheet-banner-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }
  .char-name {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    letter-spacing: 0.05em;
    color: var(--text);
  }
  .char-class {
    font-family: var(--mono);
    font-size: 0.9rem;
    color: var(--dim);
    letter-spacing: 0.04em;
  }
  .download-btn {
    display: inline-block;
    margin-top: 0.6rem;
    font-family: var(--mono);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: var(--option);
    background: transparent;
    border: 1.5px solid var(--option-border);
    border-radius: 999px;
    padding: 0.55rem 1.2rem;
    text-decoration: none;
    transition: color 0.12s ease, border-color 0.12s ease, background 0.12s ease;
  }
  .download-btn:hover, .download-btn:focus-visible {
    color: var(--btn-hover-text);
    border-color: var(--btn-hover-border);
    background: var(--btn-hover-bg, transparent);
  }
  .download-btn:focus-visible {
    outline: 2px solid var(--btn-hover-border);
    outline-offset: 2px;
  }

  .sheet-main {
    max-width: 760px;
    margin: 2rem auto 0;
    padding: 0 1.5rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Panels — same language as .card on / */
  .panel {
    background: var(--card);
    border: 1px solid var(--card-edge);
    border-radius: 18px;
    box-shadow: var(--card-shadow);
    padding: 1.75rem 2rem;
    transition: background 0.4s ease, border-color 0.4s ease;
  }
  .panel h2 {
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    background: var(--chip-bg);
    color: var(--chip-text);
    display: inline-block;
    padding: 0.32rem 0.8rem;
    border-radius: 999px;
    margin-bottom: 1.4rem;
  }

  /* Skills */
  .skill-groups {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .skill-group h3 {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--stage);
    margin-bottom: 0.75rem;
  }
  .skill-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .skill-list li {
    font-size: 0.9rem;
    color: var(--text);
  }

  /* Quest Log */
  .quest {
    padding: 1.2rem 0;
    border-top: 1px solid var(--card-edge);
  }
  .quest:first-of-type {
    border-top: none;
    padding-top: 0;
  }
  .quest-header {
    margin-bottom: 0.75rem;
  }
  .quest-header h3 {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: bold;
    color: var(--text);
    margin-bottom: 0.15rem;
  }
  .quest-meta {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--dim);
    letter-spacing: 0.04em;
  }
  .quest p {
    font-size: 0.92rem;
    color: var(--text);
    margin-bottom: 0.6rem;
    line-height: 1.55;
  }
  .quest ul {
    padding-left: 1.2rem;
    margin-bottom: 0.6rem;
  }
  .quest li {
    font-size: 0.88rem;
    color: var(--text);
    margin-bottom: 0.3rem;
    line-height: 1.45;
  }

  /* Achievements */
  .achievement-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .achievement-list li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .achievement-name {
    font-size: 0.95rem;
    color: var(--text);
  }
  .achievement-meta {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--dim);
    letter-spacing: 0.04em;
  }

  /* Contact */
  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .contact-link {
    font-family: var(--mono);
    font-size: 0.9rem;
    color: var(--option);
    text-decoration: none;
    letter-spacing: 0.04em;
    border-bottom: 1px solid var(--option-border);
    padding-bottom: 1px;
    transition: color 0.12s ease, border-color 0.12s ease;
  }
  .contact-link:hover, .contact-link:focus-visible {
    color: var(--btn-hover-text);
    border-color: var(--btn-hover-border);
  }
  .contact-link:focus-visible {
    outline: 2px solid var(--btn-hover-border);
    outline-offset: 2px;
  }

  /* Footer */
  .sheet-foot {
    max-width: 760px;
    margin: 0 auto 2.5rem;
    padding: 0 1.5rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--dim);
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .skill-groups { grid-template-columns: 1fr; }
    .sheet-banner { padding: 3rem 1rem 1.5rem; }
    .sheet-main   { padding: 0 1rem 2rem; }
    .panel        { padding: 1.3rem 1.2rem; }
  }
  @media (max-width: 400px) {
    .contact-list { flex-direction: column; gap: 0.75rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sheet-banner, .panel, .download-btn, .contact-link { transition: none; }
  }
</style>
